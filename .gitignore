.cursor/dbhub/node_modules/
.cursor/dbhub/package-lock.json

# Environment
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db
*:Zone.Identifier
**/*:Zone.Identifier

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build artifacts
build/
out/

# Native libraries (DLL files - too large for Git)
*.dll
**/native-libs/

# Local MCP configuration
.cursor/mcp.json

# Eclipse/IDE project metadata inside resources (не коммитим)
code/femsq-backend/femsq-reports/src/main/resources/reports/embedded/.project

# Local Python tooling (эксперименты, не коммитим)
.venv_excel/

# Excel working files (не коммитим бинарные xlsx/xls)
*.xlsx
*.xls
*.xlsm

# Скриншоты ошибок SQL/ODBC — только локально на nb-win (каталог: docs/sql_err/images/README.md)
docs/sql_err/images/**/*.png
docs/sql_err/images/**/*.PNG
docs/sql_err/images/**/*.jpg
docs/sql_err/images/**/*.jpeg
docs/sql_err/images/**/*.gif
docs/sql_err/images/**/*.bmp

# Локальный кэш Excel (канонические файлы — на SMB-шаре nb-win, mount /mnt/nb-win-share)
/docs/excel/

# Deploy flash packages (built artifacts, not source)
docs/development/notes/sql/**/*_deploy/open/
docs/development/notes/sql/**/*_deploy/archive/*.zip
docs/development/notes/sql/**/*_deploy/.venv_build/
docs/development/notes/sql/**/*_deploy/MANIFEST.sha256

# Python bytecode
__pycache__/
*.pyc

code/femsq-backend/temp/
code/temp/
code/femsq-backend/femsq-web/temp/

# JasperReports: скомпилированные шаблоны (в репозитории — только *.jrxml; .jasper собирает Maven)
**/temp/**/*.jasper
# Исходники отчётов только в femsq-reports/src/main/resources/reports/embedded/ (не дублировать в temp/)
**/temp/**/*.jrxml