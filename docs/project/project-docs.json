              "sql_server_product": "Microsoft SQL Server 2022 (dev only)",
              "notes": "Для проверки совместимости с продуктивом использовать скрипты из подпапки MSSQL2012/ и/или COMPATIBILITY_LEVEL=110. Приёмка планов UtPl по stCost (К-12/К-13): fixture dev-only, см. dev_acceptance_plan_stcost в database."
            },
            "dbhub": {
              "type": "local",
              "path": ".cursor/dbhub",
