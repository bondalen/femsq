            "hostname_pattern": "^nb-win$",
            "os_pattern": ".*Linux.*|.*WSL.*",
            "priority": 1,
            "database": {
              "type": "docker",
              "container_name": "femsq-mssql",
              "host": "localhost",
              "port": 1433,
              "database": "FishEye",
              "schema": "ags",
