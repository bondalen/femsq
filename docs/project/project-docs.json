              "name": "w10-26-0310",
              "purpose": "MS Access / Excel с ODBC к Docker SQL"
            },
            "wireguard": {
              "interface": "nb-win-cloud-ru",
              "host_ip": "10.7.0.3",
              "sql_port": 1433,
              "purpose": "Доступ удалённых клиентов (Fedora, DBeaver, Cursor) к Docker SQL Server",
